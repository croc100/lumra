{
  "name": "lumra-cloud",
  "version": "0.1.0",
  "private": true,
  "description": "Lumra Cloud — signed measurement ingest + query API (Cloudflare Workers + D1)",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "migrate:local": "wrangler d1 migrations apply lumra --local",
    "migrate:remote": "wrangler d1 migrations apply lumra --remote",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260714.1",
    "typescript": "^5.5.0",
    "wrangler": "^4.20.0"
  }
}
